# ============================================================
#  .env.example — Collaborative Workspace API
#
#  SETUP :
#    cp .env.example .env.local
#    # puis éditer .env.local avec vos vraies valeurs
#
#  Le fichier .env.local est exclu du dépôt git (.gitignore).
#  En production, définissez ces variables directement sur le serveur.
# ============================================================

# --- Django core ---
# Générer une clé secrète forte :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-generate-a-real-secret-key

# 'True' en développement, 'False' en production OBLIGATOIRE
DJANGO_DEBUG=True

# Hosts autorisés (séparés par des virgules)
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# --- Base de données (production PostgreSQL) ---
# DB_NAME=trello_db
# DB_USER=postgres
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432

# --- Email SMTP ---
# Utiliser un App Password Gmail (pas le mot de passe du compte)
# https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here

# --- CORS ---
# Origines frontend autorisées (séparées par des virgules)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- URL interne de l'API (utilisée par le frontend Django templates) ---
API_BASE_URL=http://localhost:8000/api/
